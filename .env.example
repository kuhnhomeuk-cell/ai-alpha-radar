# Anthropic API — Step 9 onwards (Claude Batch + Sonnet)
ANTHROPIC_API_KEY=

# xAI / Grok — Wave 6 X-mention signal per trend (Responses API with x_search)
XAI_API_KEY=

# GitHub Personal Access Token — Step 4 onwards (repo + read:org scope)
GH_PAT=

# Semantic Scholar API key — Step 5 (free signup at semanticscholar.org)
SEMANTIC_SCHOLAR_KEY=

# Cloudflare Worker URL — Step 13 (CORS + AI proxy)
WORKER_URL=

# Perplexity Sonar — Wave 5 pain-point enrichment (per-trend creator-struggle queries)
PERPLEXITY_API_KEY=

# Firecrawl — Digg AI cross-reference fetcher (pipeline/fetch/digg.py)
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Reddit OAuth — bypasses the 403 wall on public RSS from datacenter IPs.
# Create a "script" app at https://www.reddit.com/prefs/apps (type: script).
# All four vars must be set together; with any missing, the fetcher falls
# back to the RSS path (which may also fail from CI).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=

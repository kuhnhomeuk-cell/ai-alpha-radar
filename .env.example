# Anthropic API — Step 9 onwards (Claude Batch + Sonnet)
ANTHROPIC_API_KEY=

# xAI / Grok — Wave 6 X-mention signal per trend (Responses API with x_search)
XAI_API_KEY=

# GitHub Personal Access Token — Step 4 onwards (repo + read:org scope)
GH_PAT=

# Semantic Scholar API key — Step 5 (free signup at semanticscholar.org)
SEMANTIC_SCHOLAR_KEY=

# Cloudflare Worker URL — Step 13 (CORS + AI proxy)
WORKER_URL=

# Perplexity Sonar — Wave 5 pain-point enrichment (per-trend creator-struggle queries)
PERPLEXITY_API_KEY=

# Firecrawl — Digg AI cross-reference fetcher (pipeline/fetch/digg.py)
# Get a key at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Reddit OAuth — bypasses the 403 wall on public RSS from datacenter IPs.
#
# CLIENT_ID + CLIENT_SECRET are enough on their own: the fetcher uses the
# read-only client_credentials grant by default (app-only, no user
# account, no plaintext password). For new apps you'll need pre-approval
# via Reddit's Responsible Builder Policy (Nov 2025) — the prefs/apps
# form silently fails for unapproved accounts.
#
# USERNAME + PASSWORD are OPTIONAL — kept only as a fallback for the
# password grant if a particular client_id has client_credentials
# disabled. Leave blank in normal operation.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=

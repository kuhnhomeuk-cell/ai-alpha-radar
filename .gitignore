# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg

# Poetry / build artifacts
dist/
build/

# Environment (never commit secrets)
.env*
!.env.example

# Caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code runtime — worktrees, skill scratch, session metadata
.claude/

# Cloudflare Worker runtime cache
worker/.wrangler/

# Scratch redesign sandbox — copies of public/index.html and public/data.json
# that get sent to outside models. Iterations stay out of git until promoted.
redesign/

# OS
.DS_Store
Thumbs.db

# Pipeline runtime artifacts
data/corpus_centroid_60d.npy
data/bluesky_mentions.sqlite
data/replicate_run_counts.json
data/.batch_state.json
# Wave 5 — operator working file fed to scripts/refresh_youtube_outliers.py.
# The processed cache data/youtube_outliers.json is committed; this raw input is not.
data/youtube_outliers_raw.json
# Fetcher corpus caches — write-through accumulation per source, regenerated
# on every pipeline run (see pipeline/persist.py). Local-only by design.
# data/digg_ai_corpus.json is the historical exception and stays tracked.
data/*_corpus.json
!data/digg_ai_corpus.json
